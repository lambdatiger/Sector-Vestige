<DefaultWindow xmlns="https://spacestation14.io"
               MinSize="320 170"
               SetSize="320 170"
               Title="Set Security Status">
    <BoxContainer Orientation="Vertical" Margin="8">
        <OptionButton Name="StatusPicker" HorizontalExpand="True"/>
        <LineEdit Name="ReasonInput" PlaceHolder="Reason (required for Wanted/Suspected/Hostile)" HorizontalExpand="True" Margin="0 6 0 0"/>
        <BoxContainer Orientation="Horizontal" Margin="0 6 0 0">
            <Button Name="OKButton" Text="Set Status" HorizontalExpand="True" Margin="0 0 4 0"/>
            <Button Name="CancelButton" Text="Cancel" HorizontalExpand="True" Margin="4 0 0 0"/>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
