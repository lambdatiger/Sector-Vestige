<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               Title="{Loc 'addressable-delivery-ui-header'}"
               SetWidth="320"
               SetHeight="420"
               MinWidth="240"
               MinHeight="200">
    <BoxContainer Orientation="Vertical" SeparationOverride="4" VerticalExpand="True">
        <Label Text="{Loc 'addressable-delivery-ui-instruction'}" />
        <Label Name="EmptyLabel" Text="{Loc 'addressable-delivery-ui-empty'}" Visible="False" />
        <ItemList Name="CrewList" VerticalExpand="True" />
        <Button Name="SendButton" Text="{Loc 'addressable-delivery-ui-send'}" Disabled="True" HorizontalExpand="True" />
    </BoxContainer>
</DefaultWindow>
