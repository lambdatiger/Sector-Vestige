## Additional Harmony statuses
criminal-records-status-monitor = Monitor
criminal-records-status-search = Search

criminal-records-console-monitor = {$name} was marked as monitored by {$officer} for: {$reason}.
criminal-records-console-search = {$name} was marked for search by {$officer} for: {$reason}.
criminal-records-console-not-monitor = {$officer} cleared the monitored status of {$name}.
criminal-records-console-not-search = {$officer} cleared the search status of {$name}.
